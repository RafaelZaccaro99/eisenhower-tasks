{
  "installCommand": "ELECTRON_SKIP_BINARY_DOWNLOAD=1 npm install",
  "buildCommand": "vite build --config vite.web.config.js",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/.well-known/oauth-authorization-server", "destination": "/api/oauth-metadata" },
    { "source": "/.well-known/oauth-protected-resource", "destination": "/api/oauth-metadata?type=protected-resource" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": { "api/mcp.js": { "maxDuration": 30 } },
  "crons": [
    {
      "path": "/api/integrations/cron-sync",
      "schedule": "0 6 * * *"
    }
  ]
}
